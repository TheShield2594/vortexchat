# Port for the signaling server
PORT=3001

# Supabase Cloud — get from app.supabase.com → your project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS — comma-separated list of allowed origins (REQUIRED in production)
# Must be set explicitly in production — the server will exit if this is
# missing or set to "*" when NODE_ENV=production.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Redis — optional. When set, two things happen:
#   1. Room state (peers, voice_states) is stored in Redis hashes so it
#      survives process restarts and is shared across all replicas.
#   2. The Socket.IO Redis adapter is attached so that socket-room broadcasts
#      (e.g. peer-joined, peer-left) are fanned out to every replica —
#      this allows Railway to run multiple signal-server instances.
# Leave unset to use the default in-memory Map + in-process adapter (single-instance only).
# REDIS_URL=redis://localhost:6379

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
