# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only — never expose to browser

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── TURN server (required for ~20% of users behind strict NAT/firewalls) ─────
# Deploy coturn (https://github.com/coturn/coturn) and fill these in.
# Without TURN, WebRTC peer connections will silently fail for those users.
# Ephemeral credentials are generated server-side via /api/turn-credentials.
TURN_URL=turn:your-turn-server:3478
TURN_SECRET=your-coturn-static-auth-secret    # server-side only — coturn static-auth-secret
# Optional: TLS TURN for networks that block UDP
TURNS_URL=turns:your-turn-server:5349

# ─── Web Push notifications ───────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key          # server-side only
VAPID_SUBJECT=mailto:admin@example.com             # mailto: or https: URL

# ─── Error monitoring (Sentry) ────────────────────────────────────────────────
# Create a project at sentry.io and paste the DSN here.
# NEXT_PUBLIC_SENTRY_DSN is safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
# Optional: set org/project for source map uploads during CI builds
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token   # server-side only

# ─── Redis (rate limiting + application cache) ───────────────────────────────
# Required for multi-instance deployments (in-memory fallback used otherwise).
#
# Option A — Standard Redis (self-hosted / Docker / any Redis server):
# REDIS_URL=redis://localhost:6379
#
# Option B — Upstash Redis (serverless / Vercel):
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token       # server-side only
#
# If both are set, REDIS_URL takes priority.

# ─── Livekit (voice channels) ─────────────────────────────────────────────────
# Optional — if not set, voice channels return 503 Unavailable.
# Get credentials from livekit.io or your self-hosted LiveKit server.
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret        # server-side only
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# ─── AI summarization (Gemini) ────────────────────────────────────────────────
# Gemini API keys are now configured per-server by each server owner
# in Server Settings → AI. No instance-level env var needed.

# ─── Steam Web API (social connections enrichment) ──────────────────────────
# Optional — if set, Steam connections will show the user's display name,
# avatar, and owned game count on their profile.
# Get a key from https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=your-steam-web-api-key            # server-side only

# ─── Google / YouTube OAuth (social connections) ────────────────────────────
# Required for YouTube channel connection via Google sign-in.
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Enable the "YouTube Data API v3" in your Google Cloud project.
# Set authorized redirect URI to: https://your-app.vercel.app/api/users/connections/youtube/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret      # server-side only

# ─── GIF search (Klipy primary, Giphy fallback) ──────────────────────────────
# Optional — if neither is set, the GIF picker is hidden in the UI.
# Klipy is preferred when both are configured (primary provider).
# Server-side keys (recommended — keeps secrets off the client):
# Klipy: get a key from partner.klipy.com
KLIPY_API_KEY=your-klipy-api-key                  # server-side only
# Giphy: get a key from developers.giphy.com (fallback only)
GIPHY_API_KEY=your-giphy-api-key                  # server-side only
# Public fallbacks — only needed if you must expose keys to the browser
# (e.g. client-side GIF picker without an API proxy). The server-side
# keys above are preferred; these are optional.
# NEXT_PUBLIC_KLIPY_API_KEY=your-klipy-api-key
# NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# ─── Cron job protection ──────────────────────────────────────────────────────
# Required to authenticate scheduled cleanup jobs (e.g. Vercel Cron).
# Set to a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret                      # server-side only

# ─── OEmbed security ──────────────────────────────────────────────────────────
# Optional comma-separated list of domains to block from link previews.
# EMBED_BLOCKED_DOMAINS=example.com,badsite.net

# ─── Step-up authentication ───────────────────────────────────────────────────
# Dedicated HMAC secret for step-up auth tokens. Required in production.
# Must NOT reuse NEXTAUTH_SECRET — generate a separate value: openssl rand -hex 32
STEP_UP_SECRET=your-step-up-secret                # server-side only

# ─── WebAuthn / Passkeys (optional overrides) ─────────────────────────────────
# Defaults to the hostname of NEXT_PUBLIC_APP_URL. Override only if needed.
# NEXT_PUBLIC_WEBAUTHN_RP_ID=your-domain.com
# NEXT_PUBLIC_APP_ORIGIN=https://your-domain.com
# SUPABASE_WEBAUTHN_VERIFY_URL=https://<project-ref>.supabase.co/functions/v1/webauthn-verify
# SUPABASE_WEBAUTHN_VERIFY_TOKEN=your-verify-token  # server-side only
