FROM node:20-alpine

RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy signal server
COPY apps/signal/package.json ./
COPY apps/signal/tsconfig.json ./
COPY apps/signal/src ./src

# Install dependencies (including typescript for build)
RUN npm install

# Copy shared package into node_modules so imports resolve at build + runtime
COPY packages/shared ./node_modules/@vortex/shared
RUN cd node_modules/@vortex/shared && npm install --omit=dev

# Build TypeScript
RUN npx tsc

# Remove dev dependencies
RUN npm prune --omit=dev

ENV NODE_ENV=production
ENV PORT=3001

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 signaluser
USER signaluser

EXPOSE 3001
CMD ["node", "dist/index.js"]
